

header {
  display: flex;
}
nav {
  flex: 2;
  padding: 30px;
}
nav ul {
  background-color: darkblue;
  padding: 0px;
  margin: 0px;
}
nav a {
  text-decoration: none;
  padding: 15px;
  display: block;
  text-align: center;
}
.nav a:hover {
  background-color: rgb(2, 2, 105);
}

ul {
  display: flex;
  background-color: tomato;
  float: right;
}
li {
  list-style: none;
  display: flex;
}

a:hover {
  background-color: tomato;
  color: white;
}

a {
  text-decoration: none;
  color: black;
  display: inline-block;
  margin-left: 30px;
}

h1 {
  text-align: center;
}

span {
  color: darkblue;
}

#top {
  text-align: center;
}

button {
  background-color: tomato;
  padding: 10px;
  color: white;
  margin-left: 100px;
}

#container {
  display: grid;
  grid-gap: 15px;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: minmax(150px, auto);

  grid-template-areas: "onearticle twoarticle threearticle";
}

#one {
  grid-area: onearticle;
  background-color: smokewhite;
}

#two {
  grid-area: twoarticle;
  background-color: smokewhite;
}

#three {
  grid-area: threearticle;
  background-color: smokewhite;
}

.mel {
  display: flex;
}
.kick {
    height: 400px;
  flex: 1;
}

h3 {
  flex: 2;
  padding-top: 50px;
  padding-left: 5px;
}

.para {
  text-align: justify;
}

#pictures {
  background-image: url("images/background.png");
}

fieldset {
  border-left: none;
  border-right: none;
  border-bottom: none;
  border-top: 3px solid white;
  margin-top: 70px;
}

legend {
  text-align: center;
  color: white;
  padding: 30px;
}

.team {
  width: 100%;
  height: 80%;
}

#container2 {
  display: grid;
  grid-gap: 10px;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(150px, auto);

  grid-template-areas: "ball contact social coach";
}

#ball {
  grid-area: ball;
}

#Contacts {
  grid-area: contact;
}

#Social {
  grid-area: social;
}

#coach {
  grid-area: coach;
}

h4 {
  color: white;
  text-align: center;
}
footer {
  text-align: right;
  color: darkblue;
  font-style: italic;
}


@media only screen and (max-width: 1200px) {
  #container {
    grid-template-columns: repeat(2, 1fr);
  }
  #container2 {
    grid-template-columns: repeat(2, 1fr);
  }
}


@media only screen and (max-width: 900px) {
  #container {
    grid-template-columns: repeat(1, 1fr);
  }
  #container2 {
    grid-template-columns: repeat(1, 1fr);
  }
  .team {
    width: 80%;
    height: 60%;
  }
}


@media only screen and (max-width: 600px) {
  nav {
    flex-direction: column;
  }
  nav ul {
    flex-direction: column;
  }
  nav a {
    padding: 10px;
  }
  .mel {
    flex-direction: column;
  }
  .kick {
    height: 200px;
  }
  h3 {
    padding-top: 20px;
  }
  .para {
    text-align: left;
  }
  fieldset {
    margin-top: 30px;
  }
  legend {
    padding: 20px;
  }
}


@media only screen and (max-width: 400px) {
  button {
    margin-left: 50px;
  }
  h4 {
    font-size: 18px;
  }
  footer {
    font-size: 14px;
  }
}

